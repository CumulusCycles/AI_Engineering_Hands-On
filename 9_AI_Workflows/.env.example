OPENAI_API_KEY=your_openai_api_key

# BASE_MODEL defaults to gpt-5-nano in code if omitted. Optional per-task overrides below.
BASE_MODEL=gpt-5-nano

# Title/description fall back to MODEL_SYNOPSIS, which falls back to BASE_MODEL.
# MODEL_SYNOPSIS=
# MODEL_TITLE=
# MODEL_DESCRIPTION=

# Story model defaults to BASE_MODEL if omitted.
MODEL_STORY=gpt-4o-mini

# Guardrails check model (defaults to BASE_MODEL). Use a different model than
# MODEL_STORY so validation is not the same model re-judging its own output.
# MODEL_STORY_GUARD=

# Max story generation attempts (initial try + retries after failed check). Default 2 = one retry.
MAX_STORY_GEN=2

# YouTube thumbnail (Images API). Generated only after full story text is successfully produced; skipped if an earlier step errors out. Saved as thumbnail.png in each run folder under OUTPUT_DIR.
MODEL_THUMBNAIL_IMAGE=gpt-image-1-mini
# Text-check model for generated thumbnails. Falls back to BASE_MODEL if omitted.
# MODEL_THUMBNAIL_TEXT_CHECK=
THUMBNAIL_SIZE=1536x1024
THUMBNAIL_QUALITY=low

# Max thumbnail generation attempts when visible text is detected by post-check.
# 2 = initial image + one retry; final attempt is kept even if text remains.
MAX_THUMBNAIL_GEN=2

# Completed runs are written under this folder (relative to cwd unless absolute).
OUTPUT_DIR=output
