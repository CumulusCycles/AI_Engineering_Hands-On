# Copy to `.env` in this directory (repo root). Never commit `.env`.

# --- Security (code defaults: meta hidden, destructive cleanse off) ---
# Local dev / demos: unauthenticated GET /api/meta/db-status and /chroma-status.
EXPOSE_META_WITHOUT_AUTH=true
# Allow POST /api/admin/cleanse (wipes SQLite + Chroma). Omit or false unless you need it.
# ALLOW_ADMIN_CLEANSE=false
# APP_ENV=development  (production requires SESSION_COOKIE_SECURE=true — see session block)

# --- OpenAI (required for POST /api/admin/openai/smoke and generation routes) ---
# Successful smoke (with key) writes one model_calls row per SDK attempt; list via GET /api/admin/model-calls/ (admin).
OPENAI_API_KEY=

# BASE_MODEL defaults to gpt-5-nano in code if omitted (base tasks).
BASE_MODEL=gpt-5-nano

# OpenAI base tasks model overrides (leave blank to use BASE_MODEL).
# OPENAI_SMOKE_MODEL=
# OPENAI_SYNOPSIS_MODEL=
# OPENAI_TITLE_MODEL=
# OPENAI_DESCRIPTION_MODEL=
# OPENAI_NLP_MODEL=

# Admin orchestration for POST /api/admin/nlp-query (defaults to OPENAI_NLP_MODEL / BASE_MODEL).
# OPENAI_ADMIN_NLP_MODEL=

# OpenAI story generation model (only story; defaults to gpt-4o-mini).
OPENAI_STORY_MODEL=gpt-4o-mini

# OpenAI guardrails parse model (defaults to BASE_MODEL).
# OPENAI_GUARDRAILS_MODEL=

# Embeddings for Chroma (document upsert on POST …/semantic-index and query on POST /api/search/semantic).
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# YouTube thumbnail (Images API). Generated only after story is produced.
# ScriptSprout accepts either name:
# - OPENAI_IMAGE_MODEL (preferred here)
# - MODEL_THUMBNAIL_IMAGE (v3-compatible)
OPENAI_IMAGE_MODEL=dall-e-3
# MODEL_THUMBNAIL_IMAGE=dall-e-3
# Target dimensions for the saved thumbnail (WxH). DALL-E 3 only allows 1024x1024,
# 1024x1792, 1792x1024; any other value (e.g. 1280x720) uses a supported API size, then resizes.
THUMBNAIL_SIZE=1280x720
THUMBNAIL_QUALITY=standard
THUMBNAIL_STYLE=vivid

# --- Paths (defaults match implementation plan) ---
# SQLITE_PATH=./data/app.db
# CHROMA_PATH=./data/chroma  (persistent Chroma; collection content_semantic_index created at startup)

# --- Admin bootstrap: set BOTH or neither (app will error if only one is set) ---
# ADMIN_USERNAME=
# ADMIN_PASSWORD=

# --- Session cookies (defaults shown) ---
# SESSION_COOKIE_NAME=scriptsprout_session
# SESSION_TTL_DAYS=7
# SESSION_COOKIE_SECURE=false
# Behind HTTPS in production, set APP_ENV=production and SESSION_COOKIE_SECURE=true (enforced).
# SESSION_COOKIE_SAMESITE=lax
# AUTHOR_EMAIL_VERIFICATION_REQUIRED=true

# --- Narration audio (Text-to-Speech) ---
# TTS model for story narration (defaults in code if unset).
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# Voice defaults used when author selects US/UK + male/female in UI.
TTS_VOICE_FEMALE_US=nova
TTS_VOICE_FEMALE_UK=fable
TTS_VOICE_MALE_US=echo
TTS_VOICE_MALE_UK=onyx
TTS_VOICE_DEFAULT=nova

# --- Behavior ---
# Guardrails loop limit is configured per content row (`guardrails_max_loops`), not via env.
# OpenAI transient retries: max API attempts per smoke call (default 2 = initial + one retry)
# TRANSIENT_RETRY_MAX_ATTEMPTS=2
